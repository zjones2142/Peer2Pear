# ── Xcode / iOS ─────────────────────────────────────────────────────────────
# Peer2Pear.xcodeproj is generated by ios/generate.sh from ios/project.yml.
# Only project.yml is committed; everyone regenerates on first clone.
ios/Peer2Pear.xcodeproj/
ios/Peer2Pear.xcworkspace/
# Xcode user-specific state (breakpoints, scheme overrides, UI state).
# xcuserdata/ always carries per-user noise.
**/xcuserdata/
**/*.xcuserstate
**/*.xcuserdatad/
# Xcode build cache / intermediate outputs.
DerivedData/
build-ios-*/  # the CMake iOS build dirs (already caught by /build*/, here for clarity)
# `ios/generate.sh` passes -derivedDataPath ios/.xcodebuild so xcodebuild
# drops its DerivedData inside the iOS dir instead of ~/Library.  Local-only
# intermediate output — 90 MB+ of .o/.swiftmodule/etc., regenerated on build.
ios/.xcodebuild/
# Per-developer Apple Developer Team ID — never commit your Team ID.
# Copy Signing.local.xcconfig.template (committed) to Signing.local.xcconfig
# and edit your local copy.  See ios/README.md → "Code signing" section.
ios/Peer2Pear/Configs/Signing.local.xcconfig

# ── SQLCipher amalgamation ──────────────────────────────────────────────────
# We DO commit sqlite3.c + sqlite3.h + LICENSE + SQLCIPHER_VERSION.txt
# (the vendored SQLCipher amalgamation generated by third_party/sqlcipher/
# fetch.sh).  *.a at the top of this file would otherwise swallow nothing
# relevant here since the amalgamation doesn't ship a .a.
!third_party/sqlcipher/sqlite3.c
!third_party/sqlcipher/sqlite3.h
!third_party/sqlcipher/LICENSE
!third_party/sqlcipher/SQLCIPHER_VERSION.txt
